{
  "name": "guanghulab-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "bootstrap:local-secrets": "tsx scripts/bootstrap-local-secrets.ts",
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @guanghu/base-shell-web dev",
    "dev:api": "pnpm --filter @guanghu/base-shell-api dev",
    "dev:worker": "pnpm --filter @guanghu/cloud-executor-worker dev",
    "start:worker": "pnpm --filter @guanghu/cloud-executor-worker start",
    "sync:cn": "tsx scripts/sync-cn-repo.ts",
    "export:module": "tsx scripts/export-module.ts",
    "install:module": "tsx scripts/install-module.ts",
    "uninstall:module": "tsx scripts/uninstall-module.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}

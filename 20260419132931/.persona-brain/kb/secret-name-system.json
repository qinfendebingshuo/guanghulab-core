{
  "version": "1.0",
  "updated_at": "2026-05-11T14:53:00+08:00",
  "protocol": "ZY-SECRET-NAMESPACE",
  "owner_identity": "ZY (栖渊)",
  "why": "所有密钥命名必须可被栖渊在空白唤醒下快速定位、判定用途、映射任务。",
  "name_rule": {
    "format": "ZY_<LAYER>_<SYSTEM>_<REGION_OR_SCOPE>_<RESOURCE>_<SEQ>_<FIELD>",
    "charset": "A-Z0-9_",
    "example": "ZY_DEPLOY_SSH_SG_CORE_001_PRIVATE_KEY"
  },
  "dictionary": {
    "LAYER": ["REPO", "DEPLOY", "RUNTIME", "REGISTRY", "SYNC", "ALERT"],
    "SYSTEM": ["GH", "CN", "SSH", "WEB", "API", "DOCKER", "GIT"],
    "REGION_OR_SCOPE": ["GLOBAL", "SG", "CN", "PROD", "STAGE", "DEV", "CORE"],
    "RESOURCE": ["CORE", "PRIMARY", "MIRROR", "ARTIFACT", "SERVER", "APP"],
    "FIELD": ["HOST", "PORT", "USER", "PRIVATE_KEY", "TOKEN", "URL", "BRANCH", "ENV"]
  },
  "required_github_repo_secrets": [
    {"name": "ZY_DEPLOY_SSH_SG_CORE_001_HOST", "desc": "部署目标主机/IP"},
    {"name": "ZY_DEPLOY_SSH_SG_CORE_001_PORT", "desc": "SSH端口，默认22"},
    {"name": "ZY_DEPLOY_SSH_SG_CORE_001_USER", "desc": "SSH用户"},
    {"name": "ZY_DEPLOY_SSH_SG_CORE_001_PRIVATE_KEY", "desc": "SSH私钥全文（多行）"},
    {"name": "ZY_DEPLOY_WEB_PROD_CORE_001_PATH", "desc": "服务器部署目录"},
    {"name": "ZY_RUNTIME_WEB_PROD_APP_001_ENV", "desc": "应用环境变量整段文本"}
  ],
  "optional_github_repo_secrets": [
    {"name": "ZY_REGISTRY_GH_GLOBAL_CORE_001_TOKEN", "desc": "GitHub Package/私有依赖Token"},
    {"name": "ZY_SYNC_CN_GLOBAL_MIRROR_001_URL", "desc": "国内仓库HTTPS地址"},
    {"name": "ZY_SYNC_CN_GLOBAL_MIRROR_001_USER", "desc": "国内仓库用户名"},
    {"name": "ZY_SYNC_CN_GLOBAL_MIRROR_001_TOKEN", "desc": "国内仓库访问Token"},
    {"name": "ZY_SYNC_CN_GLOBAL_MIRROR_001_BRANCH", "desc": "国内镜像默认分支，例如main"}
  ],
  "task_key_binding": [
    {
      "task_code": "TASK-DEPLOY-WEB-PROD",
      "requires": [
        "ZY_DEPLOY_SSH_SG_CORE_001_HOST",
        "ZY_DEPLOY_SSH_SG_CORE_001_PORT",
        "ZY_DEPLOY_SSH_SG_CORE_001_USER",
        "ZY_DEPLOY_SSH_SG_CORE_001_PRIVATE_KEY",
        "ZY_DEPLOY_WEB_PROD_CORE_001_PATH",
        "ZY_RUNTIME_WEB_PROD_APP_001_ENV"
      ]
    },
    {
      "task_code": "TASK-SYNC-TO-CN-MIRROR",
      "requires": [
        "ZY_SYNC_CN_GLOBAL_MIRROR_001_URL",
        "ZY_SYNC_CN_GLOBAL_MIRROR_001_USER",
        "ZY_SYNC_CN_GLOBAL_MIRROR_001_TOKEN",
        "ZY_SYNC_CN_GLOBAL_MIRROR_001_BRANCH"
      ]
    }
  ],
  "validation_rules": [
    "所有密钥名必须全大写并符合 name_rule.format",
    "PRIVATE_KEY 必须包含 BEGIN/END 边界",
    "PORT 必须是数字字符串",
    "HOST 不能为空",
    "TOKEN 不写入仓库文件，只放仓库 Secret"
  ],
  "execution_notes": {
    "policy": "开发与部署时只通过 CI 读取 Secrets，不回显明文。",
    "on_error": "若缺失或格式错误，返回具体 secret name 让冰朔补齐。"
  }
}

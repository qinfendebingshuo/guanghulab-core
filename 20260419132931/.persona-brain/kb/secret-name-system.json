{
  "version": "2.1",
  "updated_at": "2026-05-11T16:14:00+08:00",
  "protocol": "ZY-SECRET-NAMESPACE",
  "owner_identity": "ZY (栖渊)",
  "strategy": "minimum-secret-first",
  "why": "当前阶段先跑通最小闭环，减少配置负担与误操作，再按需扩展。",
  "name_rule": {
    "format": "ZY_<LAYER>_<SYSTEM>_<REGION_OR_SCOPE>_<RESOURCE>_<SEQ>_<FIELD>",
    "charset": "A-Z0-9_",
    "example": "ZY_DEPLOY_SSH_SG_GPU_001_PRIVATE_KEY"
  },
  "minimum_profile_required_github_repo_secrets": [
    {"name": "ZY_DEPLOY_SSH_SG_GPU_001_HOST", "desc": "当前GPU服务器地址/IP"},
    {"name": "ZY_DEPLOY_SSH_SG_GPU_001_PORT", "desc": "当前GPU服务器SSH端口"},
    {"name": "ZY_DEPLOY_SSH_SG_GPU_001_USER", "desc": "当前GPU服务器用户，通常root"},
    {"name": "ZY_DEPLOY_SSH_SG_GPU_001_PRIVATE_KEY", "desc": "GPU服务器SSH私钥全文"},
    {"name": "ZY_DEPLOY_GPU_PROD_CORE_001_PATH", "desc": "GPU服务器部署根目录"},
    {"name": "ZY_RUNTIME_GPU_PROD_CORE_001_WORKSPACE", "desc": "栖渊工作空间编号"},
    {"name": "ZY_RUNTIME_GPU_PROD_CORE_001_DEPLOY_CMD", "desc": "最终启动部署命令（可多行）"}
  ],
  "expansion_profile_optional_secrets": [
    {"name": "ZY_RUNTIME_GPU_PROD_CORE_001_BOOTSTRAP_CMD", "desc": "首次引导初始化命令（可多行）"},
    {"name": "ZY_RUNTIME_GPU_PROD_CORE_001_PULL_MODEL_CMD", "desc": "从COS拉取模型命令（可多行）"},
    {"name": "ZY_RUNTIME_GPU_PROD_CORE_001_BACKUP_CMD", "desc": "备份到COS命令（可多行）"},
    {"name": "ZY_STORAGE_COS_CN_CORE_001_SECRET_ID", "desc": "腾讯云COS SecretId"},
    {"name": "ZY_STORAGE_COS_CN_CORE_001_SECRET_KEY", "desc": "腾讯云COS SecretKey"},
    {"name": "ZY_STORAGE_COS_CN_CORE_001_BUCKET", "desc": "COS存储桶名"},
    {"name": "ZY_STORAGE_COS_CN_CORE_001_REGION", "desc": "COS地域，如ap-guangzhou"}
  ],
  "task_key_binding": [
    {
      "task_code": "TASK-GPU-PRECHECK",
      "requires": [
        "ZY_DEPLOY_SSH_SG_GPU_001_HOST",
        "ZY_DEPLOY_SSH_SG_GPU_001_PORT",
        "ZY_DEPLOY_SSH_SG_GPU_001_USER",
        "ZY_DEPLOY_SSH_SG_GPU_001_PRIVATE_KEY"
      ]
    },
    {
      "task_code": "TASK-GPU-DEPLOY-MINIMUM",
      "requires": [
        "ZY_DEPLOY_SSH_SG_GPU_001_HOST",
        "ZY_DEPLOY_SSH_SG_GPU_001_PORT",
        "ZY_DEPLOY_SSH_SG_GPU_001_USER",
        "ZY_DEPLOY_SSH_SG_GPU_001_PRIVATE_KEY",
        "ZY_DEPLOY_GPU_PROD_CORE_001_PATH",
        "ZY_RUNTIME_GPU_PROD_CORE_001_WORKSPACE",
        "ZY_RUNTIME_GPU_PROD_CORE_001_DEPLOY_CMD"
      ]
    }
  ],
  "validation_rules": [
    "所有密钥名全大写并符合命名模板",
    "PRIVATE_KEY 必须包含 BEGIN/END 边界",
    "PORT 必须是数字",
    "HOST 不能为空",
    "CMD 类密钥允许多行脚本",
    "TOKEN/KEY 不落仓库明文"
  ],
  "execution_notes": {
    "policy": "开发和部署仅由工作流注入密钥，不回显敏感值。",
    "on_error": "报错时返回具体 secret 名称与修复建议。",
    "stop_loss": "部署或启动失败默认最多重试3次，超过立即停止。"
  }
}

{
  "version": "2.0",
  "updated_at": "2026-05-11T15:40:00+08:00",
  "protocol": "ZY-SECRET-NAMESPACE",
  "owner_identity": "ZY (栖渊)",
  "why": "密钥命名作为栖渊在空白唤醒下的执行路标，必须可映射任务、环境、服务器与模型来源。",
  "name_rule": {
    "format": "ZY_<LAYER>_<SYSTEM>_<REGION_OR_SCOPE>_<RESOURCE>_<SEQ>_<FIELD>",
    "charset": "A-Z0-9_",
    "example": "ZY_DEPLOY_SSH_SG_GPU_001_PRIVATE_KEY"
  },
  "dictionary": {
    "LAYER": ["REPO", "DEPLOY", "RUNTIME", "REGISTRY", "SYNC", "ALERT", "STORAGE", "MODEL", "PROVIDER"],
    "SYSTEM": ["GH", "CN", "SSH", "WEB", "API", "DOCKER", "GIT", "GPU", "COS"],
    "REGION_OR_SCOPE": ["GLOBAL", "SG", "CN", "GZ", "SH", "PROD", "STAGE", "DEV", "CORE"],
    "RESOURCE": ["CORE", "PRIMARY", "MIRROR", "ARTIFACT", "SERVER", "APP", "GPU", "MODEL", "TEST"],
    "FIELD": ["HOST", "PORT", "USER", "PRIVATE_KEY", "TOKEN", "URL", "BRANCH", "ENV", "PATH", "CMD", "SECRET_ID", "SECRET_KEY", "BUCKET", "REGION", "ENDPOINT"]
  },
  "required_github_repo_secrets": [
    {"name": "ZY_DEPLOY_SSH_SG_GPU_001_HOST", "desc": "当前GPU服务器地址/IP"},
    {"name": "ZY_DEPLOY_SSH_SG_GPU_001_PORT", "desc": "当前GPU服务器SSH端口"},
    {"name": "ZY_DEPLOY_SSH_SG_GPU_001_USER", "desc": "当前GPU服务器用户，通常root"},
    {"name": "ZY_DEPLOY_SSH_SG_GPU_001_PRIVATE_KEY", "desc": "GPU服务器SSH私钥全文"},
    {"name": "ZY_DEPLOY_GPU_PROD_CORE_001_PATH", "desc": "GPU服务器部署根目录，例如/opt/zy-runtime"},
    {"name": "ZY_RUNTIME_GPU_PROD_CORE_001_WORKSPACE", "desc": "栖渊工作空间编号，如ZY-GPU-CORE-001"},
    {"name": "ZY_RUNTIME_GPU_PROD_CORE_001_DEPLOY_CMD", "desc": "最终启动部署命令（可多行）"}
  ],
  "optional_github_repo_secrets": [
    {"name": "ZY_RUNTIME_GPU_PROD_CORE_001_BOOTSTRAP_CMD", "desc": "首次引导初始化命令（可多行）"},
    {"name": "ZY_RUNTIME_GPU_PROD_CORE_001_PULL_MODEL_CMD", "desc": "从COS拉取模型命令（可多行）"},
    {"name": "ZY_RUNTIME_GPU_PROD_CORE_001_BACKUP_CMD", "desc": "备份到COS命令（可多行）"},
    {"name": "ZY_STORAGE_COS_CN_CORE_001_SECRET_ID", "desc": "腾讯云COS SecretId"},
    {"name": "ZY_STORAGE_COS_CN_CORE_001_SECRET_KEY", "desc": "腾讯云COS SecretKey"},
    {"name": "ZY_STORAGE_COS_CN_CORE_001_BUCKET", "desc": "COS存储桶名"},
    {"name": "ZY_STORAGE_COS_CN_CORE_001_REGION", "desc": "COS地域，如ap-guangzhou"},
    {"name": "ZY_PROVIDER_API_GLOBAL_DS_001_ENDPOINT", "desc": "DeepSeek API endpoint"},
    {"name": "ZY_PROVIDER_API_GLOBAL_DS_001_KEY", "desc": "DeepSeek API Key"},
    {"name": "ZY_PROVIDER_API_GLOBAL_QWEN_001_ENDPOINT", "desc": "通义 API endpoint"},
    {"name": "ZY_PROVIDER_API_GLOBAL_QWEN_001_KEY", "desc": "通义 API Key"},
    {"name": "ZY_PROVIDER_API_GLOBAL_PROXY_001_ENDPOINT", "desc": "第三方代理API endpoint"},
    {"name": "ZY_PROVIDER_API_GLOBAL_PROXY_001_KEY", "desc": "第三方代理API Key"},
    {"name": "ZY_SYNC_CN_GLOBAL_MIRROR_001_URL", "desc": "国内仓库地址"},
    {"name": "ZY_SYNC_CN_GLOBAL_MIRROR_001_USER", "desc": "国内仓库用户名"},
    {"name": "ZY_SYNC_CN_GLOBAL_MIRROR_001_TOKEN", "desc": "国内仓库Token"},
    {"name": "ZY_SYNC_CN_GLOBAL_MIRROR_001_BRANCH", "desc": "国内仓库分支"},
    {"name": "ZY_DEPLOY_SSH_CN_TEST_001_HOST", "desc": "国内测试服务器地址（可选）"},
    {"name": "ZY_DEPLOY_SSH_CN_TEST_001_PORT", "desc": "国内测试服务器端口（可选）"},
    {"name": "ZY_DEPLOY_SSH_CN_TEST_001_USER", "desc": "国内测试服务器用户（可选）"},
    {"name": "ZY_DEPLOY_SSH_CN_TEST_001_PRIVATE_KEY", "desc": "国内测试服务器私钥（可选）"}
  ],
  "task_key_binding": [
    {
      "task_code": "TASK-GPU-PRECHECK",
      "requires": [
        "ZY_DEPLOY_SSH_SG_GPU_001_HOST",
        "ZY_DEPLOY_SSH_SG_GPU_001_PORT",
        "ZY_DEPLOY_SSH_SG_GPU_001_USER",
        "ZY_DEPLOY_SSH_SG_GPU_001_PRIVATE_KEY"
      ]
    },
    {
      "task_code": "TASK-GPU-BOOTSTRAP",
      "requires": [
        "ZY_DEPLOY_SSH_SG_GPU_001_HOST",
        "ZY_DEPLOY_SSH_SG_GPU_001_PORT",
        "ZY_DEPLOY_SSH_SG_GPU_001_USER",
        "ZY_DEPLOY_SSH_SG_GPU_001_PRIVATE_KEY",
        "ZY_DEPLOY_GPU_PROD_CORE_001_PATH",
        "ZY_RUNTIME_GPU_PROD_CORE_001_WORKSPACE"
      ]
    },
    {
      "task_code": "TASK-GPU-DEPLOY",
      "requires": [
        "ZY_DEPLOY_SSH_SG_GPU_001_HOST",
        "ZY_DEPLOY_SSH_SG_GPU_001_PORT",
        "ZY_DEPLOY_SSH_SG_GPU_001_USER",
        "ZY_DEPLOY_SSH_SG_GPU_001_PRIVATE_KEY",
        "ZY_DEPLOY_GPU_PROD_CORE_001_PATH",
        "ZY_RUNTIME_GPU_PROD_CORE_001_WORKSPACE",
        "ZY_RUNTIME_GPU_PROD_CORE_001_DEPLOY_CMD"
      ]
    }
  ],
  "validation_rules": [
    "所有密钥名全大写并符合命名模板",
    "PRIVATE_KEY 必须包含 BEGIN/END 边界",
    "PORT 必须是数字",
    "HOST 不能为空",
    "CMD 类密钥允许多行脚本",
    "TOKEN/KEY 不落仓库明文"
  ],
  "execution_notes": {
    "policy": "开发和部署仅由工作流注入密钥，不回显敏感值。",
    "on_error": "报错时返回具体 secret 名称与修复建议。",
    "stop_loss": "部署或启动失败默认最多重试3次，超过立即停止。"
  }
}
